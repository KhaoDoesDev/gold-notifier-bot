{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "gold-notifier-bot",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-11",
	"observability": {
		"enabled": true
	},
	"triggers": {
		"crons": [
			"* * * * *"
		]
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"secrets": {
		"required": [
			"LINE_CHANNEL_ACCESS_TOKEN",
			"LINE_USER_ID"
		],
	},
	"kv_namespaces": [
		{
			"binding": "GOLD_KV",
		}
	],
}
